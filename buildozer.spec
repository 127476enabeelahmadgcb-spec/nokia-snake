[app]
title = Nokia Snake
package.name = nokiasnake
package.domain = org.snake
source.dir = .
source.include_exts = py
version = 1.0
requirements = python3,kivy
orientation = portrait
fullscreen = 1
android.permissions = VIBRATE
android.api = 31
android.minapi = 21
android.ndk_api = 21

[buildozer]
log_level = 2
warn_on_root = 1
